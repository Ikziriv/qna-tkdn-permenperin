# =============================================================================
#  Environment Configuration Template
# =============================================================================
#  Copy this file to .env (backend) and .env.local (frontend) and fill in
#  your values. Never commit real secrets to version control.
#
#  Quick start for local development:
#    1. cp .env.example .env
#    2. Fill in DATABASE_URL and JWT_SECRET
#    3. npm run server        # Backend on http://localhost:4000
#    4. npm run dev           # Frontend on http://localhost:3000
# =============================================================================

# ---------------------------------------------------------------------------
#  SERVER-SIDE VARIABLES  (used by Express backend)
#  Place these in a file named `.env` in the project root.
#  The server loads them automatically via dotenv.
# ---------------------------------------------------------------------------

# --- Core ---
# NODE_ENV controls environment mode: development | production | staging | test
NODE_ENV=development

# PORT the Express server listens on. Railway overrides this automatically.
PORT=4000

# --- Database (Required) ---
# PostgreSQL connection string. Must start with postgresql:// or postgres://
# For local dev, you can use a Docker PostgreSQL container or a cloud provider.
DATABASE_URL=postgresql://user:password@localhost:5432/tkdn_quiz

# --- Security (Required in production) ---
# JWT signing secret. Must be at least 32 characters.
# Generate a secure value locally:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_a_secure_random_string_at_least_32_chars

# Cookie signing secret. Falls back to JWT_SECRET if not set.
# Use a separate value in production for defence in depth.
# COOKIE_SECRET=replace_with_a_different_secure_random_string

# --- CORS (Required in production) ---
# Comma-separated list of allowed frontend origins.
# In development this defaults to "true" (allow all), which is safe for localhost.
# In production this MUST be set to your deployed frontend domain(s).
# CORS_ORIGIN=https://qna-tkdn.up.railway.app,https://www.yourcustomdomain.com

# --- Rate Limiting (Optional) ---
# Window duration in milliseconds for the sliding rate-limit window.
# RATE_LIMIT_WINDOW_MS=60000

# Maximum requests allowed per window per IP.
# RATE_LIMIT_MAX=100

# --- Database Pool (Optional) ---
# Maximum number of concurrent database connections.
# RATE_LIMIT_DB_POOL_MAX=10

# ---------------------------------------------------------------------------
#  CLIENT-SIDE VARIABLES  (used by Vite during build)
#  Place these in files named `.env.development` and `.env.production`.
#  Vite ONLY exposes env vars prefixed with VITE_ to the browser.
# ---------------------------------------------------------------------------

# --- Development ---
# In development the Vite dev server proxies /api to localhost:4000,
# so the client can use a relative path.
# VITE_API_URL=/api

# --- Production ---
# In production the frontend must know the absolute backend URL.
# Update this to match your deployed backend before running `npm run build`.
# VITE_API_URL=https://qna-tkdn.up.railway.app/api

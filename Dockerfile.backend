# syntax=docker/dockerfile:1

FROM node:22-alpine
WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY server ./server
COPY lib ./lib
COPY drizzle ./drizzle
COPY types.ts ./
COPY constants.ts ./
COPY i18next.d.ts ./
COPY i18n.ts ./
COPY metadata.json ./
COPY tsconfig.json ./
COPY index.html ./

ENV NODE_ENV=production
EXPOSE 4000
CMD ["npm", "run", "server"]
